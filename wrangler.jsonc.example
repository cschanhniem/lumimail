{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "lumimail",
	"main": "./worker.ts",
	"compatibility_date": "2026-05-20",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": ".open-next/assets",
	},
	"images": {
		"binding": "IMAGES",
	},
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "lumimail",
		},
	],
	"vars": {
		"CF_TOKEN": "cf-token",
		"CF_ACCOUNT_ID": "cf-account-id",
		// Outbound provider: "cloudflare" (default, verified recipients only) or
		// "resend" (arbitrary recipients). For "resend", set RESEND_API_KEY via
		// `wrangler secret put RESEND_API_KEY` and keep the send_email binding below.
		"MAIL_PROVIDER": "cloudflare",
	},
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,
	"send_email": [
		{
			"name": "EMAIL",
			"remote": true,
		},
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "lumimail",
			"database_id": "your-d1-db-id",
			"migrations_dir": "drizzle/migrations",
		},
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "lumimail-raw",
		},
	],
	"queues": {
		"producers": [
			{
				"binding": "INBOUND_QUEUE",
				"queue": "lumimail-inbound",
			},
			{
				"binding": "OUTBOUND_QUEUE",
				"queue": "lumimail-outbound",
			},
		],
		"consumers": [
			{
				"queue": "lumimail-inbound",
				"max_batch_size": 5,
				"max_retries": 3,
			},
			{
				"queue": "lumimail-outbound",
				"max_batch_size": 5,
				"max_retries": 3,
			},
		],
	},
}