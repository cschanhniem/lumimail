NEXTJS_ENV=development
# Preferred: scoped API token.
# This is an app runtime token, not the Cloudflare deploy/build token.
CF_TOKEN=your_api_token_with_zone_email_permissions
CF_ACCOUNT_ID=your_account_id
CF_EMAIL_WORKER_NAME=lumimail

# Legacy Global API Key alternative. Use this only instead of CF_TOKEN.
# CF_EMAIL=you@example.com
# CF_API_KEY=your_global_api_key

# Outbound mail provider: "cloudflare" (default) or "resend".
# Cloudflare only delivers to verified destination addresses; use "resend" to
# deliver to arbitrary recipients on a verified sending domain.
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_api_key
# RESEND_BASE_URL=https://api.resend.com
