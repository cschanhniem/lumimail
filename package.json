{
  "name": "email-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run test:cov",
    "deploy": "npm run db:migrate:remote && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:m:l": "npm run db:migrate:local",
    "db:m:r": "npm run db:migrate:remote",
    "db:seed": "curl -X POST http://localhost:3000/api/seed"
  },
  "cloudflare": {
    "bindings": {
      "CF_TOKEN": {
        "description": "Runtime Cloudflare API token used by Lumimail onboarding to call the Zones and Email Routing APIs. Cloudflare's deploy/build token is not passed to the app, so create this separately at https://dash.cloudflare.com/profile/api-tokens with `Zone Read`, `Email Routing Edit`, `Email Sending Edit`, and `Email Routing Rules Write` permissions for the zones you will connect. Paste only the token secret value, without `Bearer`."
      },
      "CF_ACCOUNT_ID": {
        "description": "Optional Cloudflare account ID. Leave blank unless your API token can access multiple accounts."
      },
      "CF_EMAIL_WORKER_NAME": {
        "description": "Worker name used when creating Cloudflare Email Routing rules. Keep this aligned with the `name` in `wrangler.jsonc`; the template default is `lumimail`."
      },
      "CF_EMAIL": {
        "description": "Legacy Global API Key auth only. Use this with `CF_API_KEY` instead of `CF_TOKEN`."
      },
      "CF_API_KEY": {
        "description": "Legacy Global API Key auth only. Prefer `CF_TOKEN` for new deployments."
      }
    }
  },
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.9",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@tanstack/react-query": "^5.100.11",
    "@tiptap/extension-link": "3.27.0",
    "@tiptap/extension-text-align": "3.27.0",
    "@tiptap/extension-underline": "3.27.0",
    "@tiptap/react": "3.27.0",
    "@tiptap/starter-kit": "3.27.0",
    "@types/dompurify": "3.2.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "3.17.0",
    "lucide-react": "^1.21.0",
    "mimetext": "^3.0.28",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "postal-mime": "^2.7.4",
    "react": "^19.1.7",
    "react-dom": "^19.1.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.7",
    "@vitest/coverage-v8": "4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "4.1.9",
    "wrangler": "^4.101.0"
  }
}
